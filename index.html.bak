<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">

<style>
  /* ============ RESET ============ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --black: #0a0a0a;
    --black-2: #131313;
    --white: #ffffff;
    --paper: #f6f4ef;
    --navy: #0d1f3e;
    --navy-2: #0a1830;
    --coral: #ff4d5e;
    --coral-dark: #e63a4e;
    --mint: #5de4a2;
    --ink-soft: rgba(10, 10, 10, 0.58);
    --ink-fade: rgba(10, 10, 10, 0.40);
    --white-soft: rgba(255, 255, 255, 0.70);
    --white-fade: rgba(255, 255, 255, 0.40);
    --rule-light: rgba(10, 10, 10, 0.10);
    --rule-dark: rgba(255, 255, 255, 0.14);
    --font: 'Geist', -apple-system, BlinkMacSystemFont, "Inter", "Söhne", system-ui, sans-serif;
  }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body {
    font-family: var(--font);
    font-weight: 400;
    color: var(--black);
    background: var(--paper);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; height: auto; }
  ::selection { background: var(--coral); color: var(--white); }

  .wrap { width: 100%; max-width: 1480px; margin: 0 auto; padding: 0 36px; position: relative; z-index: 2; }
  @media (max-width: 768px) { .wrap { padding: 0 20px; } }

  /* ============ STAGE CURTAIN BACKDROP ============ */
  /* Used in hero, "Many paths", partners sections */
  .stage {
    position: relative;
    background: var(--black);
    overflow: hidden;
    isolation: isolate;
  }
  .stage::before {
    /* curtain stripes — pleated drapery, sharper bands */
    content: '';
    position: absolute; inset: 0;
    background:
      repeating-linear-gradient(90deg,
        rgba(255, 255, 255, 0.00) 0px,
        rgba(255, 255, 255, 0.07) 3px,
        rgba(255, 255, 255, 0.07) 14px,
        rgba(0, 0, 0, 0.55) 28px,
        rgba(0, 0, 0, 0.55) 38px,
        rgba(255, 255, 255, 0.00) 64px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.92;
  }
  .stage::after {
    /* light glow — variable per section */
    content: '';
    position: absolute; inset: -8%;
    background:
      radial-gradient(ellipse 50% 70% at 75% 40%, var(--glow, rgba(255, 90, 100, 0.55)) 0%, transparent 60%),
      radial-gradient(ellipse 35% 55% at 85% 55%, var(--glow-2, rgba(255, 140, 100, 0.30)) 0%, transparent 55%),
      radial-gradient(ellipse 25% 45% at 65% 30%, var(--glow-3, rgba(255, 200, 140, 0.18)) 0%, transparent 60%);
    pointer-events: none;
    z-index: 1;
    filter: blur(2px);
    animation: stage-breathe 14s ease-in-out infinite;
    will-change: transform, opacity;
    mix-blend-mode: screen;
  }
  .stage--glow-red { --glow: rgba(255, 90, 100, 0.55); --glow-2: rgba(255, 140, 100, 0.32); --glow-3: rgba(255, 200, 140, 0.18); }
  .stage--glow-teal { --glow: rgba(80, 220, 200, 0.35); --glow-2: rgba(120, 200, 220, 0.22); --glow-3: rgba(180, 240, 220, 0.12); }
  .stage--glow-amber { --glow: rgba(255, 180, 120, 0.40); --glow-2: rgba(255, 140, 90, 0.25); --glow-3: rgba(255, 220, 150, 0.14); }
  .stage--glow-center::after {
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, var(--glow, rgba(80, 220, 200, 0.35)) 0%, transparent 60%),
      radial-gradient(ellipse 35% 50% at 35% 60%, var(--glow-2, rgba(120, 200, 220, 0.22)) 0%, transparent 55%),
      radial-gradient(ellipse 30% 45% at 70% 40%, var(--glow-3, rgba(180, 240, 220, 0.16)) 0%, transparent 55%);
    animation: stage-breathe-center 18s ease-in-out infinite;
  }
  .stage > * { position: relative; z-index: 2; }

  @keyframes stage-breathe {
    0%, 100% { transform: translate(0%, 0%) scale(1); opacity: 1; }
    20%      { transform: translate(-2.5%, 1.5%) scale(1.06); opacity: 0.88; }
    40%      { transform: translate(2%, -1%) scale(1.12); opacity: 1; }
    60%      { transform: translate(-1.5%, 2.5%) scale(1.04); opacity: 0.92; }
    80%      { transform: translate(1.5%, -2%) scale(1.09); opacity: 0.96; }
  }
  @keyframes stage-breathe-center {
    0%, 100% { transform: translate(0%, 0%) scale(1) rotate(0deg); opacity: 1; }
    33%      { transform: translate(2%, -1.5%) scale(1.08) rotate(0.4deg); opacity: 0.90; }
    66%      { transform: translate(-2%, 1.5%) scale(1.05) rotate(-0.3deg); opacity: 0.94; }
  }

  /* Curtain stripe subtle shimmer */
  .stage::before {
    animation: curtain-shimmer 22s ease-in-out infinite;
    will-change: opacity;
  }
  @keyframes curtain-shimmer {
    0%, 100% { opacity: 0.82; }
    50%      { opacity: 0.95; }
  }

  /* ============ THE PILL — Tenity's signature graphic ============ */
  .pill {
    display: inline-block;
    width: 1.45em;
    height: 0.62em;
    background: currentColor;
    border-radius: 999px;
    vertical-align: 0.14em;
    margin: 0 0.08em;
  }
  .pill--outline {
    background: transparent;
    border: 0.08em solid currentColor;
  }

  /* ============ NAV ============ */
  .nav {
    position: fixed;
    top: 22px; left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 18px 14px 26px;
    background: var(--white);
    border-radius: 999px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.10);
    width: calc(100% - 32px);
    max-width: 1200px;
    gap: 24px;
    transition: top 240ms ease, box-shadow 240ms ease;
  }
  .nav.is-shrunk { top: 14px; box-shadow: 0 6px 24px rgba(0, 0, 0, 0.18); }
  .nav__logo { display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 17px; letter-spacing: -0.015em; color: var(--black); }
  .nav__logo-svg { width: 22px; height: 22px; }
  .nav__menu { display: flex; align-items: center; gap: 22px; }
  .nav__link { font-size: 14px; font-weight: 500; color: var(--black); transition: color 240ms; }
  .nav__link:hover { color: var(--coral); }
  .nav__cta {
    padding: 10px 18px;
    background: var(--coral);
    color: var(--white);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    transition: background 240ms;
  }
  .nav__cta:hover { background: var(--coral-dark); }
  @media (max-width: 820px) { .nav__menu { gap: 14px; } .nav__link { font-size: 12px; } }
  @media (max-width: 640px) {
    .nav { padding: 10px 12px 10px 18px; }
    .nav__menu .nav__link { display: none; }
  }

  /* ============ HERO ============ */
  .hero {
    min-height: 100vh;
    padding: 130px 36px 80px;
    color: var(--white);
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--black);
  }
  /* Hero curtain — Tenity-style, right half only, real fabric tones */
  .hero.stage::before {
    inset: auto;
    top: 0; right: 0; bottom: 0;
    width: 62%;
    background:
      repeating-linear-gradient(90deg,
        #06010a 0px,
        #1a0610 11px,
        #3d1020 23px,
        #5c1828 32px,
        #3d1020 41px,
        #1a0610 53px,
        #06010a 64px);
    opacity: 1;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.30) 8%, black 22%, black 100%);
    mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.30) 8%, black 22%, black 100%);
    animation: curtain-shimmer 22s ease-in-out infinite;
  }
  .hero.stage::after {
    inset: auto;
    top: 0; right: 0; bottom: 0;
    width: 62%;
    background:
      radial-gradient(ellipse 48% 75% at 52% 50%,
        rgba(255, 110, 110, 0.55) 0%,
        rgba(210, 60, 80, 0.32) 30%,
        transparent 65%),
      radial-gradient(ellipse 22% 45% at 92% 22%,
        rgba(80, 120, 230, 0.22) 0%,
        transparent 55%),
      radial-gradient(ellipse 30% 55% at 78% 78%,
        rgba(255, 140, 100, 0.20) 0%,
        transparent 55%);
    filter: blur(3px);
    mix-blend-mode: screen;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.30) 8%, black 22%, black 100%);
    mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.30) 8%, black 22%, black 100%);
    animation: stage-breathe 14s ease-in-out infinite;
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 80px;
    align-items: end;
    max-width: 1480px;
    margin: 0 auto;
    width: 100%;
    padding-top: 60px;
  }
  .hero__title {
    font-size: clamp(56px, 9.5vw, 168px);
    font-weight: 700;
    line-height: 0.96;
    letter-spacing: -0.045em;
    color: var(--white);
  }
  .hero__title .pill {
    background: var(--white);
    color: var(--white);
  }
  .hero__title em {
    font-style: normal;
    color: var(--white);
  }
  .hero__lead {
    font-size: clamp(16px, 1.3vw, 20px);
    color: var(--white-soft);
    line-height: 1.5;
    max-width: 460px;
    margin-bottom: 32px;
  }
  .hero__ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  @media (max-width: 900px) {
    .hero__grid { grid-template-columns: 1fr; gap: 40px; padding-top: 40px; }
    .hero { padding: 110px 20px 60px; }
  }

  /* ============ PILL BUTTON ============ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 6px 14px 22px;
    border: 1.5px solid currentColor;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    transition: background 240ms, color 240ms, border-color 240ms;
    color: inherit;
    cursor: pointer;
    background: transparent;
    font-family: var(--font);
  }
  .btn__arrow {
    width: 38px; height: 38px;
    border-radius: 999px;
    border: 1.5px solid currentColor;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 280ms, background 240ms, color 240ms;
  }
  .btn:hover .btn__arrow { transform: translateX(4px); }
  .btn--white { color: var(--white); }
  .btn--white:hover { background: var(--white); color: var(--black); }
  .btn--white:hover .btn__arrow { background: var(--black); color: var(--white); border-color: var(--black); }
  .btn--black { color: var(--black); }
  .btn--black:hover { background: var(--black); color: var(--white); }
  .btn--black:hover .btn__arrow { background: var(--white); color: var(--black); border-color: var(--white); }
  .btn--coral { background: var(--coral); color: var(--white); border-color: var(--coral); padding: 14px 6px 14px 22px; }
  .btn--coral .btn__arrow { background: var(--white); color: var(--coral); border-color: var(--white); }
  .btn--coral:hover { background: var(--coral-dark); border-color: var(--coral-dark); }

  /* ============ SECTION BASE ============ */
  .section { padding: 130px 36px; position: relative; }
  @media (max-width: 768px) { .section { padding: 80px 20px; } }
  .section--white { background: var(--white); color: var(--black); }
  .section--navy { background: var(--navy); color: var(--white); }
  .section--paper { background: var(--paper); color: var(--black); }

  .eyebrow {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.02em;
    display: inline-flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 28px;
  }
  .eyebrow::before {
    content: '';
    display: inline-block;
    width: 28px; height: 1.5px;
    background: var(--coral);
  }
  .section--white .eyebrow { color: var(--ink-soft); }
  .section--white .eyebrow::before { background: var(--coral); }
  .section--paper .eyebrow { color: var(--ink-soft); }
  .section--navy .eyebrow { color: var(--white-soft); }

  .section__title {
    font-size: clamp(48px, 7.4vw, 124px);
    font-weight: 700;
    line-height: 0.96;
    letter-spacing: -0.04em;
    color: inherit;
  }
  .section__title .pill {
    background: var(--black);
  }
  .section--navy .section__title .pill,
  .section--dark .section__title .pill,
  .stage .section__title .pill { background: var(--white); }

  /* ============ METHOD — hybrid model ============ */
  .method {
    padding: 130px 36px 130px;
  }
  @media (max-width: 768px) { .method { padding: 80px 20px; } }
  .method__title {
    font-size: clamp(36px, 5vw, 76px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.035em;
    margin-top: 16px;
    margin-bottom: 64px;
    color: var(--ink);
    max-width: 1080px;
  }
  .method__title em { font-style: normal; color: var(--coral); }
  .method__grid {
    margin-top: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
    align-items: stretch;
  }
  @media (max-width: 1024px) { .method__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .method__grid { grid-template-columns: 1fr; } }
  .method__card {
    text-decoration: none;
    color: var(--white);
    cursor: pointer;
    padding-bottom: 64px;
  }
  .method__card-arrow {
    position: absolute;
    bottom: 22px; right: 22px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.30);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: var(--white);
    transition: transform 280ms, background 240ms, color 240ms, border-color 240ms;
  }
  .method__card:hover .method__card-arrow {
    background: var(--coral);
    color: var(--white);
    border-color: var(--coral);
    transform: translate(3px, -3px);
  }
  .method__hero {
    aspect-ratio: 4 / 5;
    border-radius: 24px;
    overflow: hidden;
    background: linear-gradient(135deg, #2c2823 0%, #0e0d0a 100%);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 36px;
  }
  .method__hero-img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }
  .method__hero::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.65) 100%);
    z-index: 1;
  }
  .method__hero-text {
    position: relative;
    z-index: 2;
    font-size: clamp(28px, 3.2vw, 56px);
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.025em;
    line-height: 1.02;
  }
  .method__hero-cta {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
  }
  .method__col { display: flex; flex-direction: column; gap: 28px; }
  .method__card {
    background: var(--black-2);
    border-radius: 20px;
    padding: 32px 28px 26px;
    color: var(--white);
    position: relative;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    transition: transform 380ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .method__card:hover { transform: translateY(-4px); }
  .method__card-dot {
    position: absolute;
    top: 22px; right: 22px;
    width: 11px; height: 11px;
    border-radius: 50%;
  }
  .method__card-dot--red { background: var(--coral); }
  .method__card-dot--blue { background: #4d8aff; }
  .method__card-dot--green { background: var(--mint); }
  .method__card-dot--amber { background: #ffb86b; }
  .method__card-num {
    font-size: 14px;
    font-weight: 600;
    color: var(--white-soft);
    margin-bottom: 36px;
  }
  .method__card-title {
    font-size: clamp(20px, 1.8vw, 26px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    line-height: 1.05;
  }
  .method__card-desc {
    font-size: 14px;
    color: var(--white-soft);
    line-height: 1.55;
    margin-top: auto;
  }
  @media (max-width: 1024px) {
    .method__grid { grid-template-columns: 1fr 1fr; }
    .method__hero { grid-column: 1 / span 2; aspect-ratio: 16 / 9; }
  }
  @media (max-width: 640px) {
    .method__grid { grid-template-columns: 1fr; }
    .method__hero { grid-column: 1; aspect-ratio: 4 / 3; }
  }

  /* ============ PARTNERS (CLINICS) ============ */
  .partners {
    padding: 110px 36px;
  }
  @media (max-width: 768px) { .partners { padding: 70px 20px; } }
  .partners__inner {
    max-width: 1480px;
    margin: 0 auto;
  }
  .partners__row {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 60px;
    align-items: center;
    padding: 28px 0;
    border-top: 1px solid var(--rule-dark);
  }
  .partners__row:first-of-type { border-top: none; }
  .partners__label {
    font-size: clamp(20px, 2vw, 28px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--white);
    line-height: 1.1;
  }
  .partners__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 32px 56px;
  }
  .partners__logo {
    font-size: clamp(16px, 1.6vw, 22px);
    font-weight: 600;
    color: var(--white);
    letter-spacing: -0.01em;
    opacity: 0.85;
    transition: opacity 240ms, transform 240ms;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .partners__logo:hover { opacity: 1; transform: translateY(-2px); color: var(--mint); }
  .partners__logo-arrow { font-size: 0.7em; opacity: 0.6; }
  .partners__cta-wrap {
    text-align: center;
    margin-top: 56px;
  }
  @media (max-width: 768px) {
    .partners__row { grid-template-columns: 1fr; gap: 24px; }
    .partners__logos { gap: 18px 28px; }
  }

  /* ============ DIFFERENCE — D-SHAPED CARDS ============ */
  .diff {
    padding: 140px 36px;
    background: var(--white);
  }
  @media (max-width: 768px) { .diff { padding: 80px 20px; } }
  .diff__title {
    font-size: clamp(56px, 10vw, 184px);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.045em;
    margin-bottom: 80px;
  }
  .diff__title .pill { background: var(--black); }
  .diff__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    overflow: visible;
  }
  .diff-card {
    border: 1.5px solid var(--black);
    border-radius: 0 50% 50% 0 / 0 50% 50% 0;
    aspect-ratio: 0.7 / 1;
    padding: 32px 30px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    margin-left: -1.5px;
    background: transparent;
    transition: background 360ms;
  }
  .diff-card:first-child { margin-left: 0; }
  .diff-card:hover { background: rgba(255, 77, 94, 0.06); }
  .diff-card__title {
    font-size: clamp(22px, 1.8vw, 28px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  @media (max-width: 1024px) {
    .diff__cards { grid-template-columns: repeat(2, 1fr); gap: 0; }
    .diff-card { aspect-ratio: 1 / 1; }
    .diff-card:nth-child(3) { margin-left: 0; }
  }
  @media (max-width: 640px) {
    .diff__cards { grid-template-columns: 1fr; }
    .diff-card { margin-left: 0; aspect-ratio: 5 / 2; border-radius: 0 999px 999px 0; padding: 24px 28px; justify-content: center; }
  }

  /* ============ PROOF IN NUMBERS ============ */
  .proof {
    padding: 130px 36px;
    background: var(--white);
  }
  @media (max-width: 768px) { .proof { padding: 80px 20px; } }
  .proof__title {
    font-size: clamp(56px, 10vw, 184px);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.045em;
    margin-bottom: 60px;
  }
  .proof__title .pill { background: var(--black); }
  .proof__list { list-style: none; }
  .proof__row {
    display: grid;
    grid-template-columns: 280px 1fr 280px;
    align-items: center;
    gap: 32px;
    padding: 36px 0;
    border-top: 1px solid var(--rule-light);
  }
  .proof__row:last-child { border-bottom: 1px solid var(--rule-light); }
  .proof__label {
    font-size: clamp(16px, 1.4vw, 22px);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .proof__num {
    font-size: clamp(80px, 11vw, 180px);
    font-weight: 700;
    color: var(--coral);
    letter-spacing: -0.045em;
    line-height: 0.95;
    text-align: center;
  }
  .proof__photo {
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    overflow: hidden;
    background: linear-gradient(135deg, #2c2823, #0e0d0a);
    position: relative;
  }
  .proof__photo::after {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 30% 30%, rgba(255, 220, 180, 0.25) 0%, transparent 50%),
      linear-gradient(135deg, rgba(80, 60, 40, 0.6) 0%, transparent 100%);
  }
  @media (max-width: 900px) {
    .proof__row { grid-template-columns: 1fr; text-align: center; gap: 16px; }
    .proof__num { font-size: clamp(72px, 18vw, 120px); }
  }

  /* ============ CASE STUDIES (D-SHAPED w/ IG) ============ */
  .cases {
    padding: 140px 36px;
    background: var(--navy);
    color: var(--white);
    position: relative;
    overflow: hidden;
  }
  .cases::before {
    content: '';
    position: absolute; inset: 0;
    background:
      repeating-linear-gradient(0deg,
        rgba(255, 255, 255, 0.02) 0px,
        rgba(255, 255, 255, 0.02) 40px,
        transparent 40px,
        transparent 80px);
    opacity: 0.5;
    pointer-events: none;
  }
  @media (max-width: 768px) { .cases { padding: 80px 20px; } }
  .cases__title {
    font-size: clamp(40px, 5.5vw, 96px);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.035em;
    text-align: center;
    max-width: 1100px;
    margin: 0 auto 80px;
  }
  .cases__title .pill { background: var(--white); }
  .cases__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: 1320px;
    margin: 0 auto;
    align-items: stretch;
  }
  .case {
    border: 1.5px solid var(--white);
    border-radius: 0 50% 50% 0 / 0 50% 50% 0;
    padding: 36px 32px;
    aspect-ratio: 0.72 / 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    margin-left: -1.5px;
    background: transparent;
    transition: background 360ms, color 360ms;
    color: var(--white);
    text-align: left;
  }
  .case:first-child { margin-left: 0; }
  .case--featured {
    background: var(--white);
    color: var(--black);
    z-index: 2;
    position: relative;
  }
  .case--featured .case__cta { color: var(--black); border-color: var(--black); }
  .case__title {
    font-size: clamp(24px, 2vw, 32px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 14px;
  }
  .case__desc {
    font-size: 14px;
    line-height: 1.55;
    opacity: 0.85;
    margin-bottom: 24px;
  }
  .case__cta {
    align-self: flex-start;
    color: inherit;
  }
  .cases__bottom {
    text-align: center;
    margin-top: 56px;
  }
  @media (max-width: 1024px) {
    .cases__grid { grid-template-columns: repeat(2, 1fr); }
    .case { aspect-ratio: 1 / 1; }
    .case:nth-child(3) { margin-left: 0; margin-top: -1.5px; }
  }
  @media (max-width: 640px) {
    .cases__grid { grid-template-columns: 1fr; }
    .case { margin-left: 0; aspect-ratio: 5 / 2; border-radius: 0 999px 999px 0; padding: 24px 28px; justify-content: center; }
  }

  /* ============ CLINICS WITH IG EMBEDS ============ */
  .clinics {
    padding: 130px 36px;
    background: var(--white);
  }
  @media (max-width: 768px) { .clinics { padding: 80px 20px; } }
  .clinics__intro { max-width: 720px; margin-bottom: 64px; }
  .clinics__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .clinic-card {
    background: var(--white);
    border: 1px solid var(--rule-light);
    border-radius: 18px;
    overflow: hidden;
    transition: transform 380ms cubic-bezier(0.2,0.8,0.2,1), border-color 360ms;
  }
  .clinic-card:hover { transform: translateY(-4px); border-color: var(--black); }
  .clinic-card__embed {
    width: 100%; height: 540px; border: 0; display: block; background: #fff;
  }
  .clinic-card__body {
    padding: 22px 22px 24px;
  }
  .clinic-card__tag {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-fade);
    margin-bottom: 8px;
  }
  .clinic-card__name {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-bottom: 6px;
    line-height: 1.1;
  }
  .clinic-card__handle {
    font-size: 14px;
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 240ms;
  }
  .clinic-card__handle:hover { color: var(--coral); }
  .clinic-card__handle-arrow { transition: transform 280ms cubic-bezier(0.2,0.8,0.2,1); }
  .clinic-card__handle:hover .clinic-card__handle-arrow { transform: translate(3px, -3px); }
  @media (max-width: 1024px) { .clinics__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 700px) { .clinics__grid { grid-template-columns: 1fr; } .clinic-card__embed { height: 600px; } }

  /* ============ AUDIENCE / MANY PATHS ============ */
  .audience {
    padding: 140px 36px;
    color: var(--white);
  }
  @media (max-width: 768px) { .audience { padding: 80px 20px; } }
  .audience__title {
    font-size: clamp(48px, 9vw, 168px);
    font-weight: 700;
    line-height: 0.94;
    letter-spacing: -0.045em;
    margin-bottom: 80px;
    color: var(--white);
  }
  .audience__title .pill { background: var(--white); }
  .audience__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .aud-card {
    background: rgba(255, 255, 255, 0.06);
    border-radius: 22px;
    padding: 36px 36px 28px;
    min-height: 240px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: background 360ms;
  }
  .aud-card:hover { background: rgba(255, 255, 255, 0.10); }
  .aud-card__title {
    font-size: clamp(24px, 2.4vw, 36px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 16px;
  }
  .aud-card__desc {
    font-size: 14px;
    color: var(--white-soft);
    line-height: 1.55;
    max-width: 420px;
    flex: 1;
  }
  .aud-card__plus {
    position: absolute;
    bottom: 22px; right: 22px;
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--coral);
    color: var(--white);
    font-size: 22px;
    font-weight: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 280ms, background 240ms;
  }
  .aud-card:hover .aud-card__plus { background: var(--coral-dark); transform: rotate(90deg) scale(1.05); }
  @media (max-width: 700px) { .audience__grid { grid-template-columns: 1fr; } }

  /* ============ BIG QUOTE / FELSEFE ============ */
  .quote {
    padding: 140px 36px;
    background: var(--white);
  }
  @media (max-width: 768px) { .quote { padding: 80px 20px; } }
  .quote__title {
    font-size: clamp(40px, 6vw, 96px);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.035em;
    margin-bottom: 60px;
  }
  .quote__title .pill { background: var(--black); }
  .quote__body {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .quote__lead {
    font-size: clamp(22px, 2.2vw, 32px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .quote__lead em { font-style: normal; color: var(--coral); }
  .quote__attr {
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin-top: 32px;
  }
  .quote__paragraphs { display: flex; flex-direction: column; gap: 18px; font-size: 15px; line-height: 1.65; color: var(--ink-soft); }
  @media (max-width: 900px) { .quote__body { grid-template-columns: 1fr; gap: 32px; } }

  /* ============ CONTACT ============ */
  .contact {
    padding: 140px 36px;
    background: var(--black);
    color: var(--white);
  }
  @media (max-width: 768px) { .contact { padding: 80px 20px; } }
  .contact__head { margin-bottom: 64px; }
  .contact__title {
    font-size: clamp(48px, 7vw, 124px);
    font-weight: 700;
    line-height: 0.96;
    letter-spacing: -0.04em;
  }
  .contact__title .pill { background: var(--white); }
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .contact__details > * + * { margin-top: 26px; }
  .contact__intro {
    font-size: clamp(16px, 1.2vw, 19px);
    color: var(--white-soft);
    line-height: 1.55;
    margin-bottom: 32px;
    max-width: 520px;
  }
  .contact__intro em { font-style: normal; color: var(--coral); font-weight: 600; }
  .contact__detail-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--white-fade); margin-bottom: 6px; }
  .contact__detail-value { font-size: 16px; font-weight: 500; line-height: 1.4; color: var(--white); }
  .contact__detail-value a { transition: color 240ms; }
  .contact__detail-value a:hover { color: var(--coral); }

  .form { display: flex; flex-direction: column; gap: 18px; }
  .form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 640px) { .form__row { grid-template-columns: 1fr; } }
  .field { position: relative; }
  .field input, .field textarea {
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.20);
    padding: 18px 0 10px;
    font-family: var(--font);
    font-size: 15px;
    color: var(--white);
    outline: none;
    transition: border-color 280ms;
  }
  .field textarea { resize: vertical; min-height: 110px; }
  .field label {
    position: absolute;
    left: 0; top: 18px;
    font-size: 14px;
    color: var(--white-fade);
    pointer-events: none;
    transition: all 280ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .field input:focus + label,
  .field input:not(:placeholder-shown) + label,
  .field textarea:focus + label,
  .field textarea:not(:placeholder-shown) + label {
    top: -8px;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--coral);
  }
  .field input:focus, .field textarea:focus { border-color: var(--coral); }
  .field--checkbox { display: flex; align-items: flex-start; gap: 10px; margin-top: 4px; font-size: 12px; line-height: 1.5; color: var(--white-soft); }
  .field--checkbox input { accent-color: var(--coral); margin-top: 2px; }
  .field--checkbox label { position: static; font-size: 12px; color: var(--white-soft); text-transform: none; letter-spacing: 0; }
  .field--checkbox a { color: var(--coral); border-bottom: 1px solid var(--coral); }
  .form__submit {
    margin-top: 12px;
    align-self: flex-start;
    cursor: pointer;
    font-family: var(--font);
    padding: 14px 6px 14px 26px;
    border: 1.5px solid var(--coral);
    border-radius: 999px;
    background: var(--coral);
    color: var(--white);
    font-size: 14px;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: background 240ms;
  }
  .form__submit-arrow {
    width: 38px; height: 38px;
    border-radius: 999px;
    background: var(--white);
    color: var(--coral);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 280ms;
  }
  .form__submit:hover { background: var(--coral-dark); border-color: var(--coral-dark); }
  .form__submit:hover .form__submit-arrow { transform: translateX(4px); }
  @media (max-width: 900px) { .contact__grid { grid-template-columns: 1fr; gap: 48px; } }

  /* ============ FOOTER ============ */
  .footer {
    padding: 110px 36px 40px;
    background: var(--black);
    color: var(--white);
    border-top: 1px solid rgba(255, 255, 255, 0.10);
  }
  @media (max-width: 768px) { .footer { padding: 70px 20px 28px; } }
  .footer__brand-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 80px;
  }
  .footer__brand {
    font-size: clamp(80px, 14vw, 220px);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.88;
    color: var(--white);
  }
  .footer__brand em {
    font-style: normal;
    color: var(--coral);
  }
  .footer__brand-tag {
    font-size: clamp(16px, 1.4vw, 22px);
    font-weight: 500;
    color: var(--white-soft);
    max-width: 360px;
    text-align: right;
  }
  .footer__cols {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 36px;
    padding: 56px 0;
    border-top: 1px solid var(--rule-dark);
    border-bottom: 1px solid var(--rule-dark);
  }
  .footer__col-title { font-size: 12px; text-transform: uppercase; letter-spacing: 0.18em; color: var(--white-fade); margin-bottom: 18px; }
  .footer__list { list-style: none; }
  .footer__list li { padding: 5px 0; font-size: 14px; color: var(--white-soft); }
  .footer__list a { transition: color 240ms; }
  .footer__list a:hover { color: var(--coral); }
  .footer__hubs {
    display: flex; flex-wrap: wrap; gap: 8px;
  }
  .footer__hub {
    font-size: 12px;
    font-weight: 500;
    color: var(--white-soft);
    padding: 6px 12px;
    border: 1px solid rgba(255, 255, 255, 0.20);
    border-radius: 999px;
  }
  .footer__hub--accent { background: var(--coral); color: var(--white); border-color: var(--coral); }
  .footer__bottom {
    margin-top: 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 12px;
    color: var(--white-fade);
  }
  .footer__bottom a:hover { color: var(--coral); }
  .footer__bottom-links { display: flex; gap: 16px; flex-wrap: wrap; }
  @media (max-width: 900px) { .footer__cols { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .footer__cols { grid-template-columns: 1fr; } .footer__brand-tag { text-align: left; } }

  /* ============ WHATSAPP FAB ============ */
  .whatsapp-fab {
    position: fixed;
    bottom: 28px; right: 28px;
    width: 58px; height: 58px;
    border-radius: 50%;
    background: #25D366;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.35);
    z-index: 90;
    animation: wa-pulse 2.6s ease-in-out infinite;
    transition: transform 280ms;
  }
  .whatsapp-fab:hover { transform: scale(1.08); }
  .whatsapp-fab svg { width: 28px; height: 28px; }
  @keyframes wa-pulse {
    0%, 100% { box-shadow: 0 8px 24px rgba(37, 211, 102, 0.35), 0 0 0 0 rgba(37, 211, 102, 0.45); }
    50% { box-shadow: 0 8px 24px rgba(37, 211, 102, 0.35), 0 0 0 14px rgba(37, 211, 102, 0); }
  }

  /* ============ MODALS ============ */
  .modal { position: fixed; inset: 0; z-index: 200; display: none; align-items: center; justify-content: center; padding: 32px; }
  .modal.is-open { display: flex; }
  .modal__backdrop { position: absolute; inset: 0; background: rgba(10, 10, 10, 0.72); backdrop-filter: blur(6px); }
  .modal__panel { position: relative; background: var(--white); max-width: 720px; width: 100%; max-height: 88vh; overflow-y: auto; padding: 56px 48px; border-radius: 18px; box-shadow: 0 32px 80px -16px rgba(0,0,0,0.4); }
  @media (max-width: 600px) { .modal__panel { padding: 36px 24px; } }
  .modal__close { position: absolute; top: 18px; right: 18px; background: none; border: 0; cursor: pointer; font-size: 28px; color: var(--black); line-height: 1; transition: transform 280ms, color 280ms; }
  .modal__close:hover { transform: rotate(90deg); color: var(--coral); }
  .modal__eyebrow { font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em; color: var(--coral); margin-bottom: 12px; }
  .modal__title { font-size: 28px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 24px; }
  .modal__body { font-size: 14px; line-height: 1.65; color: var(--black); }
  .modal__body p { margin-bottom: 14px; }
  .modal__body h4 { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--black); margin: 24px 0 8px; }
  .modal__body ul { margin: 8px 0 14px 20px; }
  .modal__body li { margin-bottom: 4px; }
  .modal__body strong { font-weight: 600; }
  .modal__body a { color: var(--coral); border-bottom: 1px solid var(--coral); }
  .modal__date { margin-top: 16px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-fade); }

  /* ============ SCROLL REVEAL ============ */
  .reveal { opacity: 0; transform: translateY(28px); transition: opacity 900ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 900ms cubic-bezier(0.2, 0.8, 0.2, 1); }
  .reveal.is-visible { opacity: 1; transform: translateY(0); }
  .reveal-d1 { transition-delay: 80ms; }
  .reveal-d2 { transition-delay: 160ms; }
  .reveal-d3 { transition-delay: 240ms; }
</style>
</head>

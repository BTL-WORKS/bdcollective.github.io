<script>
  // Scroll reveal
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.10, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  // Nav shrink on scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) nav.classList.add('is-shrunk');
    else nav.classList.remove('is-shrunk');
  }, { passive: true });

  // Curtain parallax — moves the glow slowly with scroll
  const stages = document.querySelectorAll('.stage');
  let ticking = false;
  function updateParallax() {
    const scrollY = window.scrollY;
    stages.forEach((stage) => {
      const rect = stage.getBoundingClientRect();
      const visible = rect.top < window.innerHeight && rect.bottom > 0;
      if (visible) {
        const offset = (rect.top * -0.08);
        stage.style.setProperty('--parallax', `${offset}px`);
        // Apply transform to the ::after via custom property
        stage.querySelectorAll(':scope::after').forEach(el => {});
      }
    });
    ticking = false;
  }
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        stages.forEach((stage) => {
          const rect = stage.getBoundingClientRect();
          const visible = rect.top < window.innerHeight && rect.bottom > 0;
          if (visible) {
            const offset = (rect.top * -0.06);
            stage.style.backgroundPositionY = `${offset}px`;
          }
        });
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  // Modal handlers
  document.querySelectorAll('[data-modal-open]').forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      const id = trigger.getAttribute('data-modal-open');
      const modal = document.getElementById(id);
      if (modal) {
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
    });
  });
  document.querySelectorAll('[data-close]').forEach(el => {
    el.addEventListener('click', () => {
      const modal = el.closest('.modal');
      if (modal) {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
    });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.modal.is-open').forEach(m => {
        m.classList.remove('is-open');
        m.setAttribute('aria-hidden', 'true');
      });
      document.body.style.overflow = '';
    }
  });
</script>

</body>
</html>
